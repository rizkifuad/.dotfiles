{
  "layer": "top",
  "position": "top",
  "height": 45,
  "spacing": 0,
  "modules-left": [
    "niri/workspaces",
    "niri/window",
  ],
  "modules-right": [
    "tray",
    "custom/pomobar",
    "network",
    "bluetooth",
    "pulseaudio",
    "cpu",
    "temperature",
    "memory",
    "clock",
  ],
  "niri/workspaces": {
    "disable-scroll": false,
    "all-outputs": false,
    "format": "{icon}",
    "on-click": "activate",
    "persistent-workspaces": {
      "*": [
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ]
    },
    "format-icons": {
      "1": "ΌηΧ",
      "2": "ΌΙΩ",
      "3": "≤░Λ┤",
      "4": "ΎΑΥ",
      "5": "ΌΙΠ",
    }
  },
  "niri/window": {
    "format": "{title}",
    "icon": true,
    "rewrite": {
      "(.*) - Thorium": "Thorium",
      "(.*) tmux (.*)": "Terminal",
      "(.*) Zen (.*)": "Zen Browser",
      "(.*) - Google Chrome(.*)": "Google Chrome"
    }
  },
  "custom/power": {
    "format": " ΎΑΣ ",
    "on-click": "systemctl poweroff",
    "tooltip": true,
    "tooltip-format": "ίΖ│όε║"
  },
  "network": {
    "format-wifi": " ≤░νρ  {essid} ",
    "format-ethernet": "ΎΑΤ  Wired ",
    "tooltip-format": "<span color='#FF1493'> ≤░Ζπ </span>{bandwidthUpBytes}  <span color='#00BFFF'> ≤░Ζλ </span>{bandwidthDownBytes}",
    "format-linked": " ≤▒αΨ  {ifname} (No IP) ",
    "format-disconnected": " ΎΒ▒  Disconnected ",
    "format-alt": " ≤░νρ  {signalStrength}% ",
    "interval": 1
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": " {icon} {capacity}% ",
    "format-charging": " ≤▒ΡΜ{capacity}%",
    "interval": 1,
    "format-icons": [
      "≤░ΓΟ",
      "≤░Β╝",
      "≤░Β┐",
      "≤░ΓΒ",
      "≤░Β╣"
    ],
    "tooltip": true
  },
  "pulseaudio": {
    "format": "{icon} {volume}% ",
    "format-muted": " ≤░ΨΒ 0% ",
    "format-icons": {
      "headphone": " ΎΑξ ",
      "hands-free": " ΎΑξ ",
      "headset": " ΎΑξ ",
      "phone": " ΎΓΧ ",
      "portable": " ΎΓΧ ",
      "car": " ΎΗ╣ ",
      "default": [
        " ΎΑο ",
        " ΎΑπ ",
        " ΎΑρ "
      ]
    },
    "on-click-right": "pavucontrol -t 3",
    "on-click": "pactl -- set-sink-mute 0 toggle",
    "tooltip": true,
    "tooltip-format": "Volume: {volume}%"
  },
  "custom/temperature": {
    "exec": "sensors | awk '/^Package id 0:/ {print int($4)}'",
    "format": " ΎΜΙ{}┬░C ",
    "interval": 1,
    "tooltip": true,
    "tooltip-format": "CPU Temp: {}┬░C"
  },
  "memory": {
    "interval": 1,
    "format": " Ό┐Ζ  <span color=\"#FFFFFF\">{used:0.1f}G/{total:0.1f}G</span> ",
    "tooltip": true,
    "tooltip-format": "Memory: {used:0.2f}G/{total:0.2f}G"
  },
  "cpu": {
    "interval": 1,
    "format": " ΌΚο  <span color=\"#FFFFFF\">{usage}%</span> ",
    "tooltip": true
  },
 "temperature": {
    // "thermal-zone": 2,
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C ΎΜΘ",
    "format": "{temperatureC}┬░C ΎΜΚ"
},
  "clock": {
    "interval": 15,
    "timezone": "Asia/Jakarta",
    "format": " {:%a, %B %d %H:%M} ",
    "tooltip": true,
    "tooltip-format": "{:L%Y ί╣┤ %m όεΙ %d όΩξ, %A}"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 16
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}{percent}% ",
    "tooltip": true,
    "tooltip-format": "ί╜ΥίΚΞί▒Πί╣Χϊ║χί║ο: {percent}%",
    "format-icons": [
      " ≤░Δη ",
      " ≤░Δζ ",
      " ≤░Δθ ",
      " ≤░Δι "
    ]
  },
  "bluetooth": {
    "format": " ΎΛΥ {status} ",
    "format-connected": " ΎΛΥ {device_alias} ",
    "format-connected-battery": " ΎΛΥ {device_alias} - {device_battery_percentage}% ",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "blueman-manager",
  },
  "custom/pomobar": {
    "format": "{icon}{text}",
    "format-icons": {
      "idle": " έΨ╢Ύ╕Π ",
      "paused": "ΏθΤν ",
      "work": "ΏθΤ╗ ",
      "short_break": "έαΧ ",
      "long_break": "ΏθΝ┐ ",
    },
    "interval": 1,
    "exec": "/home/rizki/.local/bin/pomobar-cli status",
    "on-click": "/home/rizki/.local/bin/pomobar-cli toggle",
    "on-click-middle": "/home/rizki/.local/bin/pomobar-cli reset",
    "return-type": "json",
  },
"custom/ycal": {
    "exec": "/usr/share/waybar-ycal/bar.py",
    "on-click": "/usr/share/waybar-ycal/toggle.sh",
    "interval": 60,
    "return-type": "json"
},
}
